# ===========================================
# 沐美服务 - 生产环境配置模板
# ===========================================
# 复制此文件为 .env 并填写配置
# cp .env.production.example .env

# ============ 必需配置 =============

PORT=3000
NODE_ENV=production

# 运行以下命令生成强密码：
# openssl rand -base64 64
JWT_SECRET=你的强密码（至少32字符）

# ============ CORS配置（生产必填）============

ALLOWED_ORIGINS=https://你的域名.com,https://www.你的域名.com

# ============ 邮件配置 =============

SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=你的SendGrid_API_Key
SMTP_FROM="沐美服务" <noreply@你的域名.com>

# ============ Stripe配置 =============

STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ============ 数据库（可选）============

# DB_TYPE=mongodb
# DB_HOST=localhost
# DB_PORT=27017
# DB_NAME=mumei_service
# DB_USER=
# DB_PASS=
