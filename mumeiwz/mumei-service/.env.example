# ===========================================
# 沐美服务环境变量配置 - 生产环境必读
# ===========================================
# 复制此文件为 .env 并填写配置
# cp .env.example .env

# ============ 必需配置（生产环境）============

# 服务器配置
PORT=3000
NODE_ENV=development  # 生产环境设为 production

# JWT密钥（生产环境必须设置！）
# 强烈建议：运行 node scripts/generate-secrets.js 生成强密码
# 或者使用以下命令生成：openssl rand -base64 64
JWT_SECRET=请在这里填入强密码（至少32字符）

# JWT过期时间（可选）
JWT_EXPIRES=7d

# ============ CORS配置 =============

# 允许的域名（生产环境必须配置）
# 多个域名用逗号分隔
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,https://your-domain.com

# ============ 邮件配置（生产环境）============

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM="沐美服务" <noreply@mumei.dev>

# Ethereal测试账户（开发环境）
# 运行 node -e "require('./email').getEtherealAccount()" 获取测试账户
ETHEREAL_USER=
ETHEREAL_PASS=

# ============ Stripe支付配置（生产环境）============

# 从 https://dashboard.stripe.com 获取密钥
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ============ 数据库配置（可选）============

# 如需使用真实数据库，取消下面的注释
# DB_TYPE=mongodb  # 或 postgresql, mysql
# DB_HOST=localhost
# DB_PORT=27017
# DB_NAME=mumei_service
# DB_USER=
# DB_PASS=

# ============ 日志配置 =============

# LOG_LEVEL=info  # debug, info, warn, error
# LOG_FILE=./logs/app.log
